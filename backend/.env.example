# Postgres connection string (required)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Server port (default 3000)
# PORT=3000

# --- Curation / question-bank script auth (optional) ---
# Base URL for scripts that call the API (e.g. question-bank --from-db). Use 127.0.0.1 on Windows to avoid localhost IPv6 issues.
# CURATION_API_URL=http://127.0.0.1:3000

# Long-lived key for scripts: set the same value here and as CURATION_API_TOKEN where the script runs.
# Curation API then accepts either an SME session token (from /curation/login) or this key.
# Generate once: e.g. openssl rand -hex 32
# CURATION_SCRIPT_API_KEY=

# Long-lived key for admin API (e.g. structure-images for question-bank). Set the same value here and as ADMIN_API_TOKEN where the script runs.
# Scripts can use ADMIN_API_TOKEN + GET /admin/curation/items/:id/structure-images instead of curation login.
# Generate once: e.g. openssl rand -hex 32
# ADMIN_API_KEY=
